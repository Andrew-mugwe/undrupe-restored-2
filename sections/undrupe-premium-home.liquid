{{ 'section-undrupe-premium-home.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}

{%- liquid
  assign featured_collection = section.settings.featured_collection
  assign hero_alt = section.settings.hero_image.alt | default: shop.name | escape
  assign editorial_alt = section.settings.editorial_image.alt | default: shop.name | escape
-%}

<section class="undrupe-home color-{{ section.settings.color_scheme }} gradient" id="undrupe-home">

  <!-- ============================================================
       HERO — Cinematic parallax with particles
       ============================================================ -->
  <div class="undrupe-hero page-width">
    <div class="undrupe-hero__copy">
      {%- if section.settings.kicker != blank -%}
        <p class="undrupe-eyebrow u-reveal u-delay-1">{{ section.settings.kicker | escape }}</p>
      {%- endif -%}

      <h1 class="undrupe-hero__heading">{{ section.settings.heading }}</h1>

      {%- if section.settings.body != blank -%}
        <div class="undrupe-hero__text u-reveal u-delay-2 rte">{{ section.settings.body }}</div>
      {%- endif -%}

      <div class="undrupe-hero__actions u-reveal u-delay-3">
        {%- if section.settings.primary_label != blank -%}
          <a
            class="button button--primary undrupe-button"
            {% if section.settings.primary_link == blank %}
              role="link" aria-disabled="true"
            {% else %}
              href="{{ section.settings.primary_link }}"
            {% endif %}
          >
            {{ section.settings.primary_label | escape }}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style="margin-left:4px"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_label != blank -%}
          <a
            class="button button--secondary undrupe-button undrupe-button--ghost"
            {% if section.settings.secondary_link == blank %}
              role="link" aria-disabled="true"
            {% else %}
              href="{{ section.settings.secondary_link }}"
            {% endif %}
          >
            {{ section.settings.secondary_label | escape }}
          </a>
        {%- endif -%}
      </div>

      <dl class="undrupe-proof u-reveal u-delay-4">
        <div>
          <dt>Premium</dt>
          <dd>Handpicked essentials</dd>
        </div>
        <div>
          <dt>Secure</dt>
          <dd>Protected checkout</dd>
        </div>
        <div>
          <dt>Fast</dt>
          <dd>Worldwide delivery</dd>
        </div>
      </dl>
    </div>

    <div class="undrupe-hero__visual" aria-hidden="true">
      <div class="undrupe-hero__image-card">
        {%- if section.settings.hero_image != blank -%}
          {{
            section.settings.hero_image
            | image_url: width: 1800
            | image_tag:
              class: 'undrupe-hero__image',
              loading: 'eager',
              fetchpriority: 'high',
              alt: hero_alt
          }}
        {%- else -%}
          <img
            class="undrupe-hero__image"
            src="{{ 'undrupe-hero-product.png' | asset_url }}"
            alt="Undrupe premium organizer detail"
            loading="eager"
            fetchpriority="high"
            width="1248"
            height="832"
          >
        {%- endif -%}
      </div>
      <div class="undrupe-floating undrupe-floating--top">
        <span>Premium</span>
        <strong>Handpicked essentials</strong>
      </div>
      <div class="undrupe-floating undrupe-floating--bottom">
        <span>Trusted</span>
        <strong>Quality checked</strong>
      </div>
    </div>
  </div>

  <!-- ============================================================
       MARQUEE — Infinite brand scroll
       ============================================================ -->
  <div class="undrupe-marquee" aria-hidden="true">
    <div class="undrupe-marquee__track">
      {%- for i in (1..2) -%}
        <span class="undrupe-marquee__item">Free Shipping on $50+</span>
        <span class="undrupe-marquee__item">Premium Curated Products</span>
        <span class="undrupe-marquee__item">30-Day Easy Returns</span>
        <span class="undrupe-marquee__item">Eco-Conscious Packaging</span>
        <span class="undrupe-marquee__item">Trusted by 10,000+ Customers</span>
        <span class="undrupe-marquee__item">New Arrivals Weekly</span>
        <span class="undrupe-marquee__item">Quality Guaranteed</span>
        <span class="undrupe-marquee__item">Secure Checkout</span>
      {%- endfor -%}
    </div>
  </div>

  <!-- ============================================================
       TRUST BAR — Glassmorphism feature cards
       ============================================================ -->
  <div class="undrupe-trust page-width" aria-label="Store benefits">
    <div class="u-reveal u-delay-1">
      <span>01</span>
      <strong>Useful first</strong>
      <p>Products chosen for real routines, not shelf clutter.</p>
    </div>
    <div class="u-reveal u-delay-2">
      <span>02</span>
      <strong>Clean quality</strong>
      <p>Simple finishes, durable details, and easy gifting.</p>
    </div>
    <div class="u-reveal u-delay-3">
      <span>03</span>
      <strong>Fair value</strong>
      <p>Elevated essentials without the boutique markup.</p>
    </div>
  </div>

  <!-- ============================================================
       FEATURED PRODUCTS — 3D tilt cards
       ============================================================ -->
  <div class="undrupe-featured page-width">
    <div class="undrupe-section-heading u-reveal">
      <div>
        <p class="undrupe-eyebrow">Trending now</p>
        <h2>{{ section.settings.featured_heading | escape }}</h2>
      </div>
      {%- if section.settings.featured_link_label != blank -%}
        <a
          {% if section.settings.featured_link == blank %}
            role="link" aria-disabled="true"
          {% else %}
            href="{{ section.settings.featured_link }}"
          {% endif %}
        >
          {{ section.settings.featured_link_label | escape }}
        </a>
      {%- endif -%}
    </div>

    {%- if featured_collection != blank and featured_collection.products_count > 0 -%}
      <ul class="grid product-grid grid--2-col-tablet-down grid--4-col-desktop undrupe-product-grid" role="list">
        {%- for product in featured_collection.products limit: section.settings.products_to_show -%}
          <li class="grid__item">
            {% render 'card-product',
              card_product: product,
              media_aspect_ratio: 'portrait',
              image_shape: 'default',
              show_secondary_image: true,
              show_vendor: false,
              show_rating: false,
              lazy_load: true,
              quick_add: section.settings.quick_add,
              section_id: section.id
            %}
          </li>
        {%- endfor -%}
      </ul>
    {%- else -%}
      <div class="undrupe-placeholder-grid">
        <article>
          <span>Home</span>
          <h3>Cable and desk organizers</h3>
          <p>Clean up the everyday surfaces customers see first.</p>
        </article>
        <article>
          <span>Tech</span>
          <h3>Smart charging essentials</h3>
          <p>Small tools that make phones, desks, and travel easier.</p>
        </article>
        <article>
          <span>Care</span>
          <h3>Hard-to-reach cleaning tools</h3>
          <p>Practical problem solvers with a polished presentation.</p>
        </article>
        <article>
          <span>Living</span>
          <h3>Storage that looks intentional</h3>
          <p>Useful pieces that belong in a modern home.</p>
        </article>
      </div>
    {%- endif -%}
  </div>

  <!-- ============================================================
       STATS BAR — animated counters
       ============================================================ -->
  <div class="undrupe-stats page-width">
    <div class="undrupe-stats__grid">
      <div class="undrupe-stat u-reveal u-delay-1">
        <span class="undrupe-stat__number" data-count-to="10000" data-count-suffix="+">0</span>
        <span class="undrupe-stat__label">Happy Customers</span>
      </div>
      <div class="undrupe-stat u-reveal u-delay-2">
        <span class="undrupe-stat__number" data-count-to="500" data-count-suffix="+">0</span>
        <span class="undrupe-stat__label">Products Curated</span>
      </div>
      <div class="undrupe-stat u-reveal u-delay-3">
        <span class="undrupe-stat__number" data-count-to="48" data-count-suffix="">0</span>
        <span class="undrupe-stat__label">Countries Shipped</span>
      </div>
      <div class="undrupe-stat u-reveal u-delay-4">
        <span class="undrupe-stat__number" data-count-to="99" data-count-suffix="%">0</span>
        <span class="undrupe-stat__label">Satisfaction Rate</span>
      </div>
    </div>
  </div>

  <!-- ============================================================
       SOLUTIONS — Interactive hover cards with glow
       ============================================================ -->
  <div class="undrupe-solutions page-width">
    <div class="undrupe-section-heading undrupe-section-heading--center u-reveal">
      <p class="undrupe-eyebrow">Shop by need</p>
      <h2>Everyday problems, solved cleanly.</h2>
    </div>

    <div class="undrupe-solution-grid">
      {%- for block in section.blocks -%}
        <a
          class="undrupe-solution"
          {% if block.settings.link == blank %}
            role="link" aria-disabled="true"
          {% else %}
            href="{{ block.settings.link }}"
          {% endif %}
          {{ block.shopify_attributes }}
        >
          <span>{{ forloop.index | prepend: '0' }}</span>
          <h3>{{ block.settings.heading | escape }}</h3>
          <p>{{ block.settings.text | escape }}</p>
        </a>
      {%- endfor -%}
    </div>
  </div>

  <!-- ============================================================
       EDITORIAL — Parallax image split
       ============================================================ -->
  <div class="undrupe-editorial page-width">
    <div class="undrupe-editorial__image u-reveal-scale">
      {%- if section.settings.editorial_image != blank -%}
        {{
          section.settings.editorial_image
          | image_url: width: 1800
          | image_tag:
            loading: 'lazy',
            alt: editorial_alt
        }}
      {%- else -%}
        <img
          src="{{ 'undrupe-editorial-home.jpg' | asset_url }}"
          alt="Minimal home setting curated by Undrupe"
          loading="lazy"
          width="2000"
          height="788"
        >
      {%- endif -%}
    </div>
    <div class="undrupe-editorial__copy u-reveal-right">
      <p class="undrupe-eyebrow">The Undrupe edit</p>
      <h2>Premium essentials for modern living.</h2>
      <p>
        Every product at Undrupe is selected for usefulness, quality, and design. No clutter, no gimmicks—just smart essentials that improve everyday life.
      </p>
      <a class="button button--primary undrupe-button" href="{{ routes.collections_url }}">
        Explore collections
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style="margin-left:4px"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>

  <!-- ============================================================
       TESTIMONIALS — Social proof with gold accent
       ============================================================ -->
  <div class="undrupe-testimonials">
    <div class="u-page-width">
      <div class="undrupe-section-heading undrupe-section-heading--center u-reveal">
        <p class="undrupe-eyebrow">What customers say</p>
        <h2>Loved by thousands worldwide.</h2>
      </div>

      <div class="undrupe-testimonials__grid">
        <div class="undrupe-testimonial u-reveal u-delay-1">
          <p class="undrupe-testimonial__text">"The quality of everything I've ordered has been incredible. Packaging is beautiful too. This is my go-to for home essentials now."</p>
          <div class="undrupe-testimonial__author">
            <div class="undrupe-testimonial__avatar">SK</div>
            <div>
              <div class="undrupe-testimonial__name">Sarah K.</div>
              <div class="undrupe-testimonial__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            </div>
          </div>
        </div>

        <div class="undrupe-testimonial u-reveal u-delay-2">
          <p class="undrupe-testimonial__text">"I bought the desk organizer set as a gift and it arrived beautifully packaged. My friend absolutely loved it. Will definitely order again."</p>
          <div class="undrupe-testimonial__author">
            <div class="undrupe-testimonial__avatar">MT</div>
            <div>
              <div class="undrupe-testimonial__name">Michael T.</div>
              <div class="undrupe-testimonial__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            </div>
          </div>
        </div>

        <div class="undrupe-testimonial u-reveal u-delay-3">
          <p class="undrupe-testimonial__text">"Finally a store that curates products thoughtfully. Everything feels premium without the luxury price tag. Shipping was super fast too!"</p>
          <div class="undrupe-testimonial__author">
            <div class="undrupe-testimonial__avatar">JL</div>
            <div>
              <div class="undrupe-testimonial__name">Jessica L.</div>
              <div class="undrupe-testimonial__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ============================================================
       NEWSLETTER — Premium dark CTA with morphing orbs
       ============================================================ -->
  <div class="undrupe-newsletter page-width">
    <div class="undrupe-newsletter__inner u-reveal-scale">
      <span class="undrupe-newsletter__kicker">Join the community</span>
      <h2>Be the first to discover new arrivals.</h2>
      <p>Subscribe to get exclusive access to curated drops, special offers, and insider tips on elevating your everyday.</p>
      {%- form 'customer', id: 'UndrupeNewsletterForm' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="undrupe-newsletter__form">
          <input
            class="undrupe-newsletter__input"
            type="email"
            name="contact[email]"
            placeholder="Enter your email address"
            required
            autocomplete="email"
            aria-label="Email address"
          >
          <button type="submit" class="undrupe-newsletter__submit">
            Subscribe
          </button>
        </div>
      {%- endform -%}
    </div>
  </div>

</section>

<!-- Premium JS Engine -->
<script src="{{ 'undrupe-premium.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Undrupe premium home",
  "tag": "section",
  "class": "section section-undrupe-premium-home",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Curated everyday essentials"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Smart essentials, beautifully chosen."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Undrupe brings together clever home, tech, and lifestyle finds that make daily routines feel cleaner, easier, and more intentional.</p>"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop new arrivals"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "View all products"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "collection",
      "id": "featured_collection",
      "label": "Featured collection"
    },
    {
      "type": "text",
      "id": "featured_heading",
      "label": "Featured heading",
      "default": "Most wanted this week"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "select",
      "id": "quick_add",
      "default": "standard",
      "label": "Quick add",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "standard",
          "label": "Standard"
        }
      ]
    },
    {
      "type": "text",
      "id": "featured_link_label",
      "label": "Featured link label",
      "default": "Shop all"
    },
    {
      "type": "url",
      "id": "featured_link",
      "label": "Featured link"
    },
    {
      "type": "image_picker",
      "id": "editorial_image",
      "label": "Editorial image"
    }
  ],
  "blocks": [
    {
      "type": "solution",
      "name": "Solution card",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Organize the messy corner"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Compact tools for cleaner counters, drawers, desks, and entryways."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Undrupe premium home",
      "blocks": [
        {
          "type": "solution",
          "settings": {
            "heading": "Tame cables and counters",
            "text": "Small organizers that make busy spaces feel immediately cleaner."
          }
        },
        {
          "type": "solution",
          "settings": {
            "heading": "Upgrade daily routines",
            "text": "Useful tech, home, and lifestyle finds that earn their place."
          }
        },
        {
          "type": "solution",
          "settings": {
            "heading": "Gift better essentials",
            "text": "Polished everyday products that feel thoughtful without overthinking."
          }
        }
      ]
    }
  ]
}
{% endschema %}
